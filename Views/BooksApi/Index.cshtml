@{
ViewData["Title"] = "Wyszukiwarka Książek API";
}

<div class="container mt-4">
    <h2>Integracja z Google Books API (Dynamiczny AJAX)</h2>
    <p class="text-muted">Wpisz tytuł książki, autora lub numer ISBN, aby automatycznie pobrać dane bez przeładowania strony.</p>

    <form id="searchForm" class="row g-3 mb-4">
        <div class="col-md-8">
            <input type="text" id="queryInput" class="form-control" placeholder="Np. Wiedźmin, Ostatnie życzenie lub 9788375747003" required />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100" id="searchBtn">
                <span id="searchSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                Pobierz dane z API
            </button>
        </div>
    </form>

    <hr />

    <div id="alertContainer"></div>

    <div id="booksResultsContainer" class="d-flex flex-column gap-4"></div>
</div>

@section Scripts {
<script>
    document.getElementById('searchForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const query = document.getElementById('queryInput').value;
        const searchBtn = document.getElementById('searchBtn');
        const searchSpinner = document.getElementById('searchSpinner');
        const container = document.getElementById('booksResultsContainer');
        const alertContainer = document.getElementById('alertContainer');

        alertContainer.innerHTML = '';
        container.innerHTML = ''; 

        searchBtn.disabled = true;
        searchSpinner.classList.remove('d-none');

        try {
            const response = await fetch('/api/booksapi/Search', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `query=${encodeURIComponent(query)}`
            });

            const data = await response.json();

            if (data.success) {
                data.books.forEach((book, index) => {

                    const imgHtml = book.thumbnailUrl
                        ? `<img src="${book.thumbnailUrl}" alt="Okładka" class="img-fluid rounded shadow" style="max-height: 220px;" />`
                        : `<div class="text-muted border p-4">Brak okładki</div>`;

                    let formatBadge = '<span class="badge bg-secondary">Książka</span>';
                    if (book.printType === 'MAGAZINE') {
                        formatBadge = '<span class="badge bg-warning text-dark">Magazyn/Czasopismo</span>';
                    } else if (book.thumbnailUrl && book.thumbnailUrl.includes("edge=curl")) {
                        formatBadge = '<span class="badge bg-info text-dark">E-Book / Cyfrowa</span>';
                    }

                    // Bezpieczne parsowanie cudzysłowów dla atrybutów danych HTML
                    const safeTitle = book.title.replace(/"/g, '&quot;');
                    const safeAuthors = (book.authors || "Nieznany autor").replace(/"/g, '&quot;');
                    const safePublisher = (book.publisher || "Nieznane wydawnictwo").replace(/"/g, '&quot;');
                    const safeDescription = (book.description || "Brak opisu").replace(/"/g, '&quot;');

                    // Generowanie HTML karty z dodatkowymi ukrytymi atrybutami data-* w buttonie
                    const bookCard = `
        <div class="card shadow-sm book-result-card">
            <div class="row g-0">
                <div class="col-md-3 text-center p-3 bg-light d-flex align-items-center justify-content-center">
                    ${imgHtml}
                </div>
                <div class="col-md-9">
                    <div class="card-body">
                        <h3 class="card-title text-primary">${book.title} ${formatBadge}</h3>
                        <h6 class="card-subtitle mb-2 text-muted"><strong>Autorzy:</strong> <span>${book.authors || "Nieznany autor"}</span></h6>
                        
                        <ul class="list-inline my-3 text-secondary">
                            <li class="list-inline-item"><strong>Wydawnictwo:</strong> <span>${book.publisher}</span></li>
                            <li class="list-inline-item">|</li>
                            <li class="list-inline-item"><strong>Data wydania:</strong> <span>${book.publishedDate}</span></li>
                            <li class="list-inline-item">|</li>
                            <li class="list-inline-item"><strong>Stron:</strong> <span class="badge bg-light text-dark border">${book.pageCount}</span></li>
                            <li class="list-inline-item">|</li>
                            <li class="list-inline-item"><strong>Język:</strong> <span class="badge bg-light text-dark border">${book.language.toUpperCase()}</span></li>
                        </ul>

                        <p class="card-text"><strong>Opis książki:</strong></p>
                        <p class="text-justify" style="max-height: 150px; overflow-y: auto;">${book.description}</p>
                        
                        <div class="mt-3">
                            <button type="button" class="btn btn-success save-book-btn" 
                                    data-title="${safeTitle}" 
                                    data-authors="${safeAuthors}" 
                                    data-publisher="${safePublisher}" 
                                    data-description="${safeDescription}" 
                                    data-image-url="${book.thumbnailUrl}"
                                    data-page-count="${book.pageCount}"
                                    data-language="${book.language}"
                                    data-print-type="${book.printType}"
                                    data-published-date="${book.publishedDate}">
                                <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                                <i class="bi bi-cloud-arrow-up"></i> Zapisz tę książkę w mojej bazie danych
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    `;
                    container.insertAdjacentHTML('beforeend', bookCard);
                });

                initSaveButtons();

            } else {
                showAlert(data.message, 'warning');
            }
        } catch (error) {
            showAlert('Wystąpił błąd podczas komunikacji z serwerem.', 'danger');
        } finally {
            searchBtn.disabled = false;
            searchSpinner.classList.add('d-none');
        }
    });

    function initSaveButtons() {
        const saveButtons = document.querySelectorAll('.save-book-btn');

        saveButtons.forEach(btn => {
            btn.addEventListener('click', async function () {
                const spinner = this.querySelector('.spinner-border');
                const currentCard = this.closest('.book-result-card');

                this.disabled = true;
                spinner.classList.remove('d-none');

                // POPRAWKA: Pobieramy dane bezpiecznie bezpośrednio z dataset przycisku
                const formData = new URLSearchParams();
                formData.append('title', this.getAttribute('data-title'));
                formData.append('authors', this.getAttribute('data-authors'));
                formData.append('publisher', this.getAttribute('data-publisher'));
                formData.append('description', this.getAttribute('data-description'));
                formData.append('imageUrl', this.getAttribute('data-image-url'));
                formData.append('pageCount', this.getAttribute('data-page-count') || "0");
                formData.append('language', this.getAttribute('data-language') || "pl");
                formData.append('printType', this.getAttribute('data-print-type') || "BOOK");
                formData.append('publishedDate', this.getAttribute('data-published-date') || ""); // <-- Wysyłamy nową zmienną

                try {
                    const response = await fetch('/api/booksapi/SaveToDatabase', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: formData.toString()
                    });

                    const data = await response.json();

                    if (data.success) {
                        showAlert(data.message, 'success');
                        currentCard.remove();
                    } else {
                        showAlert(data.message, 'danger');
                        this.disabled = false;
                    }
                } catch (error) {
                    showAlert('Błąd podczas zapisu książki.', 'danger');
                    this.disabled = false;
                } finally {
                    spinner.classList.add('d-none');
                }
            });
        });
    }

    function showAlert(message, type) {
        const alertContainer = document.getElementById('alertContainer');
        const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
        alertContainer.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    <i class="bi ${icon} me-2"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>
}
}