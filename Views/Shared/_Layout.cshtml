@using Microsoft.AspNetCore.Http
@{
// Pobieramy dane z sesji na samym początku
var userLogin = Context.Session.GetString("User");
var userRole = Context.Session.GetString("UserRole");
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - meow 🐾</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="bg-light text-secondary d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm py-3" style="background-color: #234465;">
    <div class="container flex-wrap flex-sm-nowrap gap-3">

        @if (userRole == "Admin")
        {
            <span class="navbar-brand fw-bold fs-4 m-0" style="cursor: default;">🐾 meow księgarnia</span>
        }
        else
        {
            <a class="navbar-brand fw-bold fs-4 m-0" href="/Shop">🐾 meow księgarnia</a>
        }

        <div class="d-flex align-items-center flex-grow-1 flex-sm-grow-0 justify-content-between gap-4 ms-auto w-100 w-sm-auto">

            @if (userRole != "Admin")
            {
                <div class="input-group" style="max-width: 240px;">
                    <input type="text" class="form-control form-control-sm" id="searchField" placeholder="Szukaj po tytule..." />
                </div>
            }

            <div class="navbar-nav flex-row align-items-center gap-3 ms-auto">
                @if (userRole != "Admin")
                {
                    <a class="nav-link text-white fw-medium small" href="/Shop">Sklep</a>

                    <a class="nav-link text-white fw-medium small position-relative" href="/Shop/Cart">
                        Koszyk
                        <span class="badge rounded-pill ms-1 cart-status text-white" style="background-color: #e67e22;">0</span>
                    </a>
                }

                @if (!string.IsNullOrEmpty(userLogin))
                {
                    if (userRole == "Admin")
                    {
                        <a class="nav-link text-white fw-medium small" href="/">Panel Admina</a>
                        <a class="nav-link text-warning fw-bold small" href="/api/booksapi/Index">➕ Importuj z API</a>
                    }
                    else
                    {
                        <a class="nav-link text-white fw-medium small" href="/Account/Profile">Mój Profil</a>
                    }

                    <form action="/Account/Logout" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-link text-white fw-medium small bg-transparent border-0 p-0" style="cursor: pointer;">
                            Wyloguj (@userLogin) 🐾
                        </button>
                    </form>
                }
                else
                {
                    <a class="nav-link text-white fw-medium small" href="/Account/Login">Zaloguj się</a>
                    <a class="nav-link text-white fw-medium small" href="/Account/Register">Rejestracja</a>
                }
            </div>
        </div>
    </div>
</nav>

<div class="container my-4 flex-grow-1">
    @RenderBody()
</div>

<footer class="text-center text-muted py-3 border-top bg-white mt-auto">
    <div class="container">
        <p class="mb-0 small">&copy; @DateTime.Now.Year - meow system biblioteczno-sklepowy 🐾</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

<script>
    // Skrypt JavaScript zabezpieczony operatorem opcjonalnego łańcuchowania (?.)
    // Dzięki temu, gdy element 'searchField' nie istnieje w DOM (u Admina), kod nie rzuci błędem.
    let originalShopHtml = null;

    document.getElementById('searchField')?.addEventListener('input', async (e) => {
        const query = e.target.value.toLowerCase().trim();
        const container = document.getElementById('books-container');

        if (!container) return;

        if (originalShopHtml === null) {
            originalShopHtml = container.innerHTML;
        }

        if (query === '') {
            container.innerHTML = originalShopHtml;
            return;
        }

        try {
            const response = await fetch('/api/booksapi');
            if (!response.ok) return;

            const books = await response.json();

            const filteredBooks = books.filter(book => {
                const tytul = (book.tytul || book.Tytul || '').toLowerCase();
                const autor = (book.autor || book.Autor || '').toLowerCase();
                return tytul.includes(query) || autor.includes(query);
            });

            container.innerHTML = '';

            if (filteredBooks.length === 0) {
                container.innerHTML = `<div class="col-12 text-center my-5 text-muted">🐾 Nie znaleziono książek spełniających kryteria.</div>`;
                return;
            }

            filteredBooks.forEach(book => {
                const bookId = book.id || book.Id;
                const tytul = book.tytul || book.Tytul;
                const autor = book.autor || book.Autor;
                const imgUrl = book.imageUrl || book.ImageUrl || '/images/default.png';
                const cena = book.cena || book.Cena || 0;

                const cardDiv = document.createElement('div');
                cardDiv.className = 'col-md-4 mb-4';
                cardDiv.innerHTML = `
                        <div class="card h-100 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                            <img src="${imgUrl}" class="card-img-top" style="height: 250px; object-fit: cover;" alt="${tytul}" />
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title" style="color: #234465; font-weight: 700;">${tytul}</h5>
                                <p class="card-text text-muted small">Autor: ${autor}</p>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-success">${parseFloat(cena).toFixed(2)} zł</span>
                                    <a href="/Shop/Details/${bookId}" class="btn btn-sm btn-outline-primary">Zobacz szczegóły</a>
                                </div>
                            </div>
                        </div>
                    `;
                container.appendChild(cardDiv);
            });

        } catch (error) {
            console.error("Błąd pobierania danych z API:", error);
        }
    });
</script>
</body>
</html>