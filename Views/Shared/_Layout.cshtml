<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - meow</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #f4f6f9;
            color: #333;
        }
        .navbar-custom {
            background-color: #234465;
        }
        .navbar-custom .navbar-brand, .navbar-custom .nav-link {
            color: #ffffff;
        }
        .navbar-custom .nav-link:hover {
            color: #f1c40f;
        }
        .cart-status {
            background-color: #e67e22;
            color: white;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }
        /* Responsywne Mega Menu */
        .mega-dropdown-menu {
            width: 100%;
            max-width: 800px;
            padding: 20px;
        }
        footer {
            background-color: #234465;
            color: rgba(255,255,255,0.7);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

<header>
    @using Microsoft.AspNetCore.Http
    @inject IHttpContextAccessor HttpContextAccessor
    @{
        var sessionUser = HttpContextAccessor.HttpContext?.Session.GetString("User");
        var sessionRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");
        var koszykString = HttpContextAccessor.HttpContext?.Session.GetString("Koszyk") ?? "";
        int iloscWKoszyku = string.IsNullOrEmpty(koszykString) ? 0 : koszykString.Split(',', StringSplitOptions.RemoveEmptyEntries).Length;
        var sessionAuthError = HttpContextAccessor.HttpContext?.Session.GetString("MeowAuthError");
    }

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm px-4 py-3">
        <div class="container-fluid">
            @if (sessionRole == "Admin")
            {
                <a href="/" class="navbar-brand fw-bold fs-4">PANEL KONTROLI 🐾</a>
            }
            else
            {
                <a href="/Shop" class="navbar-brand fw-bold fs-4">E-Księgarnia 🐾</a>
            }

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Przełącz nawigację">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-2">
                    @if (sessionRole == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link fw-bold text-warning" href="/">🏠 Pulpit Zarządczy</a></li>
                        <li class="nav-item"><a class="nav-link text-warning" href="/Books/Create">[Admin] Dodaj książki</a></li>
                        <li class="nav-item"><a class="nav-link text-warning" href="/Books">[Admin] Stan Magazynowy</a></li>
                        <li class="nav-item"><a class="nav-link text-warning" href="/Rentals/Returns">[Admin] Zamówienia</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link fw-bold" href="http://localhost:8000/">🏠 Strona Główna</a></li>
                        
                        <li class="nav-item dropdown position-static">
                            <a class="nav-link dropdown-toggle" href="#" id="megaMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Kategorie ▾
                            </a>
                            <div class="dropdown-menu mega-dropdown-menu p-4 shadow-lg border-0 container rounded-3" aria-labelledby="megaMenu">
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <h6 class="fw-bold text-primary border-bottom pb-2">Polecane</h6>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Biografia">Biografie</a>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Biznes">Biznes</a>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Fantasy">Fantastyka</a>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Kryminał">Kryminał i thriller</a>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <h6 class="fw-bold text-primary border-bottom pb-2">Kultura i Nauka</h6>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Powieść">Literatura piękna</a>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Naukowe">Nauki ścisłe</a>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Popularnonaukowa">Popularnonaukowe</a>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Poradniki">Poradniki</a>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <h6 class="fw-bold text-primary border-bottom pb-2">Dla dzieci i rozwój</h6>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Wiek-3-5">Wiek 3-5 lat</a>
                                        <a class="dropdown-item py-1" href="/Shop?gatunek=Wiek-6-8">Wiek 6-8 lat</a>
                                        <a class="dropdown-item py-1 fw-bold text-success" href="/Shop?gatunek=Psychologia">Psychologia</a>
                                    </div>
                                </div>
                            </div>
                        </li>
                    }
                </ul>

                @if (sessionRole != "Admin")
                {
                    <form action="/Shop" method="get" class="d-flex mx-lg-auto my-2 my-lg-0 w-100 style-search-form" style="max-width: 500px;">
                        <input type="search" name="fraza" value="@ViewBag.WybranaFraza" class="form-control me-2" placeholder="Tytuł lub autor... 🐾" aria-label="Szukaj">
                        @if (!string.IsNullOrEmpty(ViewBag.AktualnyGatunek))
                        {
                            <input type="hidden" name="gatunek" value="@ViewBag.AktualnyGatunek" />
                        }
                        <button class="btn btn-outline-light" type="submit">Szukaj</button>
                    </form>
                }

                <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0 text-white">
                    @if (sessionUser != null)
                    {
                        <span class="small text-light">Witaj, <strong>@sessionUser</strong></span>
                        @if (sessionRole != "Admin")
                        {
                            <a href="/Account/Profile" class="btn btn-sm btn-warning text-dark fw-bold"><i class="bi bi-person"></i> Konto</a>
                        }
                        <a href="/Account/Logout" class="btn btn-sm btn-danger fw-bold">Wyloguj</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-sm btn-outline-light">Zaloguj się</a>
                        <a href="/Account/Register" class="btn btn-sm btn-warning text-dark fw-bold">Rejestracja</a>
                    }

                    @if (sessionRole != "Admin")
                    {
                        <a href="/Shop/Cart" class="text-white text-decoration-none ms-2">
                            <i class="bi bi-cart3 fs-5"></i> <span class="cart-status ms-1">@iloscWKoszyku</span>
                        </a>
                    }
                </div>

            </div>
        </div>
    </nav>
</header>

<div class="container my-5 flex-grow-1">
    
    @if (!string.IsNullOrEmpty(sessionAuthError))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @sessionAuthError
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        HttpContextAccessor.HttpContext?.Session.Remove("MeowAuthError");
    }

    @if (TempData["Message"] != null)
    {
        var alertClass = TempData["MessageType"]?.ToString() == "success" ? "alert-success" : 
            (TempData["MessageType"]?.ToString() == "warning" ? "alert-warning" : "alert-danger");
        var iconClass = TempData["MessageType"]?.ToString() == "success" ? "bi-check-circle-fill" : "bi-exclamation-circle-fill";
                  
        <div class="alert @alertClass alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi @iconClass me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @RenderBody()
</div>

<footer class="text-center py-4 mt-auto border-top text-secondary">
    <div class="container">
        &copy; @DateTime.Now.Year E-Księgarnia Internetowa. Wszystkie prawa zastrzeżone.
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Automatyczne znikanie alertów sukcesu po 5 sekundach
        const alerts = document.querySelectorAll('.alert-success');
        alerts.forEach(function(alert) {
            setTimeout(function() {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }, 5000);
        });
    });
</script>

</body>
</html>