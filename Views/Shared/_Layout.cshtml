<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - meow</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f6f9;
            color: #333;
        }
        header {
            background-color: #234465;
            color: white;
            padding: 15px 40px;
        }
        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .logo {
            font-size: 24px;
            font-weight: bold;
            letter-spacing: 1px;
        }
        .search-container {
            display: flex;
            flex-grow: 0.5;
            max-width: 600px;
        }
        .search-input {
            width: 100%;
            padding: 10px 15px;
            border: none;
            border-radius: 4px 0 0 4px;
            font-size: 14px;
        }
        .search-btn {
            background-color: #1a3047;
            color: white;
            border: none;
            padding: 0 20px;
            border-radius: 0 4px 4px 0;
            cursor: pointer;
            font-weight: bold;
        }
        .search-btn:hover { background-color: #112031; }

        nav {
            display: flex;
            gap: 25px;
            align-items: center;
            font-size: 15px;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 10px;
        }
        nav a {
            color: #e0e0e0;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }
        nav a:hover { color: white; }

        .cart-status {
            background-color: #e67e22;
            color: white;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: bold;
        }
        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }
        footer {
            background-color: #234465;
            color: rgba(255,255,255,0.7);
            text-align: center;
            padding: 20px;
            margin-top: 50px;
            font-size: 14px;
        }

        /* --- STYLE DLA MEGA MENU --- */
        .mega-dropdown {
            position: relative;
            display: inline-block;
        }

        .mega-dropdown-btn {
            cursor: pointer;
        }

        .mega-dropdown-content {
            display: none;
            position: absolute;
            left: 0;
            top: 100%;
            background-color: #ffffff;
            min-width: 850px;
            box-shadow: 0px 8px 24px rgba(0,0,0,0.15);
            border-radius: 6px;
            padding: 25px;
            z-index: 1000;
            margin-top: 10px;
            gap: 40px;
        }

        .mega-dropdown:hover .mega-dropdown-content {
            display: flex;
        }

        .mega-column {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .mega-column h3 {
            font-size: 15px;
            color: #234465;
            margin: 0 0 10px 0;
            font-weight: 700;
            border-bottom: 1px solid #eef2f5;
            padding-bottom: 5px;
        }

        .mega-column a {
            color: #444444 !important;
            text-decoration: none;
            font-size: 14px;
            font-weight: normal;
            padding: 3px 0;
            transition: color 0.15s, padding-left 0.15s;
        }

        .mega-column a:hover {
            color: #e67e22 !important;
            padding-left: 5px;
        }

        .mega-column a.highlight {
            color: #e67e22 !important;
            font-weight: 600;
        }
        .mega-column a.highlight:hover {
            color: #d35400 !important;
        }
    </style>
</head>
<body>

<header>
    @using Microsoft.AspNetCore.Http
    @inject IHttpContextAccessor HttpContextAccessor
    @{
        var sessionUser = HttpContextAccessor.HttpContext?.Session.GetString("User");
        var sessionRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");

        var koszykString = HttpContextAccessor.HttpContext?.Session.GetString("Koszyk") ?? "";
        int iloscWKoszyku = string.IsNullOrEmpty(koszykString) 
            ? 0 
            : koszykString.Split(',', StringSplitOptions.RemoveEmptyEntries).Length;
            
   
        var sessionAuthError = HttpContextAccessor.HttpContext?.Session.GetString("MeowAuthError");
    }

    <div class="header-top">
        @if (sessionRole == "Admin")
        {
            <a href="/" class="logo" style="text-decoration: none; color: white;"> PANEL KONTROLI 🐾</a>
        }
        else
        {
            <a href="/Shop" class="logo" style="text-decoration: none; color: white;"> E-Księgarnia 🐾</a>
        }

        @if (sessionRole != "Admin")
        {
            <form action="/Shop" method="get" class="search-container">
                <input type="text" 
                       name="fraza" 
                       value="@ViewBag.WybranaFraza" 
                       class="search-input" 
                       placeholder="Wpisz tytuł lub autora ... 🐾">
               
                @if (!string.IsNullOrEmpty(ViewBag.AktualnyGatunek))
                {
                    <input type="hidden" name="gatunek" value="@ViewBag.AktualnyGatunek" />
                }
        
                <button type="submit" class="search-btn">SZUKAJ</button>
            </form>
        }
        else
        {
            <div style="flex-grow: 0.5;"></div>
        }

        <div style="display: flex; gap: 20px; align-items: center;">
            @if (sessionUser != null)
            {
                <span style="font-size: 14px;">Witaj, <strong>@sessionUser</strong> (@sessionRole)</span>
                
                @if (sessionRole != "Admin")
                {
                    <a href="/Account/Profile" style="color: #f1c40f; text-decoration: none; font-weight: bold;">👤 Moje Konto</a>
                }
                
                <a href="/Account/Logout" style="color: #ff6b6b; text-decoration: none; font-weight: bold;">Wyloguj</a>
            }
            else
            {
                <a href="/Account/Login" style="color: white; text-decoration: none; font-weight: bold;">Zaloguj się</a>
                <a href="/Account/Register" style="color: #f39c12; text-decoration: none; font-weight: bold;">Rejestracja</a>
            }
        </div>
    </div>

    <nav>
        @if (sessionRole == "Admin")
        {
            <a href="/" style="font-weight: bold; color: #f1c40f;">🏠 Pulpit Zarządczy</a>
            <a href="/Books/Create" style="color: #f1c40f; font-weight: bold;">[Admin] Dodaj książki</a>
            <a href="/Books" style="color: #f1c40f;">[Admin] Stan Magazynowy</a>
            <a href="/Rentals/Returns" style="color: #f1c40f; font-weight: bold;">[Admin] Zamówienia i Wypożyczenia</a>
        }
        else
        {
            <a href="http://localhost:8000/" style="font-weight: bold; color: #f1c40f;">🏠 Strona Główna</a>

            <div class="mega-dropdown">
                <a href="#" class="mega-dropdown-btn">Kategorie ▾</a>
                <div class="mega-dropdown-content">
                    <div class="mega-column">
                        <h3>Polecane</h3>
                        <a href="/Shop?gatunek=Biografia">Biografie</a>
                        <a href="/Shop?gatunek=Biznes">Biznes</a>
                        <a href="/Shop?gatunek=Ezoteryka i parapsychologia">Ezoteryka i parapsychologia</a>
                        <a href="/Shop?gatunek=Fantasy">Fantastyka</a>
                        <a href="/Shop?gatunek=Historia">Historia</a>
                        <a href="/Shop?gatunek=Komiksy, Mangy">Komiksy</a>
                        <a href="/Shop?gatunek=Kryminał">Kryminał, sensacja, thriller</a>
                        <a href="/Shop?gatunek=Wiek-6-8" class="highlight">Książki dla dzieci</a>
                        <a href="/Shop?gatunek=Dla młodzieży">Książki dla młodzieży</a>
                        <a href="/Shop?gatunek=Kuchnia i diety">Kuchnia i diety</a>
                    </div>
                    <div class="mega-column">
                        <h3>Kultura i sztuka</h3>
                        <a href="/Shop?gatunek=Popularnonaukowa">Literature faktu, reportaż</a>
                        <a href="/Shop?gatunek=Literatura obcojęzyczna">Literatura obyczajowa</a>
                        <a href="/Shop?gatunek=Literatura obyczajowa">Literatura obyczajowa</a>
                        <a href="/Shop?gatunek=Powieść">Literatura piękna</a>
                        <a href="/Shop?gatunek=Nauka języków">Nauka języków</a>
                        <a href="/Shop?gatunek=Nauki humanistyczne">Nauki humanistyczne</a>
                        <a href="/Shop?gatunek=Naukowe">Nauki ścisłe, medycyna</a>
                        <a href="/Shop?gatunek=Podręczniki akademickie">Podręczniki akademickie</a>
                        <a href="/Shop?gatunek=Podróże i turystyka">Podróże i turystyka</a>
                        <a href="/Shop?gatunek=Poezja">Poezja i drama</a>
                        <a href="/Shop?gatunek=Popularnonaukowa">Popularnonaukowe</a>
                        <a href="/Shop?gatunek=Poradniki">Poradniki</a>
                        <a href="/Shop?gatunek=Prawo">Prawo</a>
                        <a href="/Shop?gatunek=Religia">Religia</a>
                        <a href="/Shop?gatunek=Sport">Sport</a>
                    </div>
                    <div class="mega-column">
                        <h3>Książki dla dzieci</h3>
                        <a href="/Shop?gatunek=Wiek-0-2">0-2 lat</a>
                        <a href="/Shop?gatunek=Wiek-3-5">3-5 lat</a>
                        <a href="/Shop?gatunek=Wiek-6-8">6-8 lat</a>
                        <a href="/Shop?gatunek=Wiek-9-12">9-12 lat</a>
                        <h3 style="margin-top: 20px;">Rozwój osobisty</h3>
                        <a href="/Shop?gatunek=Emocje">Emocje i uczucia</a>
                        <a href="/Shop?gatunek=Kariera">Kariera i sukces</a>
                        <a href="/Shop?gatunek=Psychologia">Psychologia i motywacja</a>
                    </div>
                </div>
            </div>
            
            
            <div style="margin-left: auto; display: flex; gap: 25px; align-items: center;">
                <a href="/Shop/Cart">🛒 Mój Koszyk <span class="cart-status">@iloscWKoszyku</span></a>
            </div>
        }
    </nav>
</header>

<div class="container">
    @if (!string.IsNullOrEmpty(sessionAuthError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px; font-weight: 500; display: flex; justify-content: space-between; align-items: center; background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
            <span>@sessionAuthError</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="background: none; border: none; font-size: 16px; cursor: pointer; color: inherit;" onclick="this.parentElement.style.display='none';">×</button>
        </div>
        
        HttpContextAccessor.HttpContext?.Session.Remove("MeowAuthError");
    }

    @if (TempData["Message"] != null)
    {
        var alertClass = TempData["MessageType"]?.ToString() == "success" ? "alert-success" : 
            (TempData["MessageType"]?.ToString() == "warning" ? "alert-warning" : "alert-danger");
                     
        <div class="alert @alertClass alert-dismissible fade show" role="alert" style="padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px; font-weight: 500; display: flex; justify-content: space-between; align-items: center; background-color: @(alertClass == "alert-success" ? "#d1e7dd" : (alertClass == "alert-warning" ? "#fff3cd" : "#f8d7da")); color: @(alertClass == "alert-success" ? "#0f5132" : (alertClass == "alert-warning" ? "#664d03" : "#842029")); border: 1px solid @(alertClass == "alert-success" ? "#badbcc" : (alertClass == "alert-warning" ? "#ffecb5" : "#f5c2c7"));">
            <span>@TempData["Message"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="background: none; border: none; font-size: 16px; cursor: pointer; color: inherit;" onclick="this.parentElement.style.display='none';">×</button>
        </div>
    }
    
    @RenderBody()
</div>

<footer>
    &copy; @DateTime.Now.Year E-Księgarnia Internetowa. Wszystkie prawa zastrzeżone.
</footer>

</body>
</html>